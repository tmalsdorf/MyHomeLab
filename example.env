# =============================================================================
# HomeLab Configuration File
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp example.env .env
# 2. Edit .env with your settings (minimum: K3S_USERNAME + one environment)
# 3. Run: ./setup.sh
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Basic Settings
# -----------------------------------------------------------------------------

# The user that Ansible will use to connect to remote hosts (must exist on all nodes)
K3S_USERNAME=ansible

# SSH key configuration
SSH_DIR="$HOME/.ssh"
KEY_FILE="$SSH_DIR/id_rsa"

# Repository settings (for cloning if not already in repo)
GITHUB_USERNAME=tmalsdorf
REPO_NAME=MyHomeLab

# -----------------------------------------------------------------------------
# REQUIRED: Choose Your Mode
# -----------------------------------------------------------------------------

# Mode A: Single Environment (simplest for getting started)
# Set ENVIRONMENT to dev, uat, or prod
ENVIRONMENT=dev

# Mode B: Multi-Environment Setup
# Set SETUP_ALL_ENVIRONMENTS=true to configure all three environments
SETUP_ALL_ENVIRONMENTS=false

# -----------------------------------------------------------------------------
# K3s Cluster Configuration
# -----------------------------------------------------------------------------
# Enable at least one environment and set the IP addresses

# Development Environment (192.168.3.x)
K3S_ENABLED_DEV=true
K3S_MASTERS_DEV="192.168.3.50"
K3S_NODES_DEV="192.168.3.51,192.168.3.52,192.168.3.53"

# UAT Environment (192.168.2.x)  
K3S_ENABLED_UAT=false
K3S_MASTERS_UAT="192.168.2.50"
K3S_NODES_UAT="192.168.2.51,192.168.2.52"

# Production Environment (192.168.1.x)
K3S_ENABLED_PROD=false
K3S_MASTERS_PROD="192.168.1.50"
K3S_NODES_PROD="192.168.1.51,192.168.1.52"

# -----------------------------------------------------------------------------
# Optional: Additional Services
# -----------------------------------------------------------------------------

# Portainer - Container management UI
PORTAINER_ENABLED=false

# ArgoCD - GitOps for Kubernetes (auto-enabled if K3s is enabled)
ARGO_ENABLED=false
ARGO_PASSWORD=changeme

# Proxmox - If using Proxmox LXC for K3s nodes
PROXMOX_SERVER_ENABLED=false

# -----------------------------------------------------------------------------
# Optional: Ansible Configuration
# -----------------------------------------------------------------------------

# These will be used to generate ansible.cfg automatically
# ANSIBLE_REMOTE_USER=ansible
# ANSIBLE_HOST_KEY_CHECKING=false
# ANSIBLE_TIMEOUT=30

# -----------------------------------------------------------------------------
# Optional: Cloud/External Integrations
# -----------------------------------------------------------------------------

AWS_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

GITHUB_ENABLED=false
GITHUB_PERSONAL_ACCESS_TOKEN=

OPENAI_API_ENABLED=false
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# System Settings
# -----------------------------------------------------------------------------

SYSTEM_TZ="America/Chicago"

# Inventory file paths (usually don't change these)
ANSIBLE_INVENTORY_BASE_PATH=inventory
ANSIBLE_INVENTORY_FILE=hosts.ini

