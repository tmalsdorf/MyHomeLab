SSH_DIR="$HOME/.ssh"
KEY_FILE="$SSH_DIR/id_rsa"

GITHUB_USERNAME=tmalsdorf
REPO_NAME=MyHomeLab

SYSTEM_TZ="America/Chicago"

# Environment Configuration
# =========================
# Set to "all" to process dev, uat, and prod in one run
# Or set to specific environment: dev, uat, prod
ENVIRONMENT=dev

# Process all environments in one run (true/false)
SETUP_ALL_ENVIRONMENTS=false

ANSIBLE_ENABLED=false
# Inventory path - will use inventory/${ENVIRONMENT}/hosts.ini
ANSIBLE_INVENTORY_BASE_PATH=inventory
ANSIBLE_INVENTORY_FILE=hosts.ini

K3S_ENABLED=false
K3S_USERNAME=""

# Development Environment K3s Cluster
# ===================================
K3S_ENABLED_DEV=false
K3S_MASTERS_DEV="192.168.3.50"
K3S_NODES_DEV="192.168.3.51,192.168.3.52"
K3S_CONTEXT_DEV=dev

# UAT Environment K3s Cluster
# ===========================
K3S_ENABLED_UAT=false
K3S_MASTERS_UAT="192.168.2.50"
K3S_NODES_UAT="192.168.2.51,192.168.2.52"
K3S_CONTEXT_UAT=uat

# Production Environment K3s Cluster
# ====================================
K3S_ENABLED_PROD=false
K3S_MASTERS_PROD="192.168.1.50"
K3S_NODES_PROD="192.168.1.51,192.168.1.52"
K3S_CONTEXT_PROD=prod

SYNOLOGY_ENABLED=false

DOCKER_SERVER_ENABLED=false

PROXMOX_SERVER_ENABLED=false

OPENAI_API_ENABLED=false
OPENAI_API_KEY=

SLACK_BOT_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_WEBHOOK_URL=

JENKINS_ENABLED=false
JENKINS_URL=http://127.0.0.1:51936
JENKINS_USERNAME=
JENKINS_PASSWORD=

ARGO_ENABLED=false
ARGO_TOKEN=
ARGO_WORKFLOWS_TOKEN=
ARGO_URL=https://localhost:8080
ARGO_WORKFLOWS_URL=https://localhost:2746

PYTHON_ENV_ENABLED=false
# Python environment (development, staging, production)
PYTHON_ENV=${ENVIRONMENT}

AWS_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

GITHUB_ENABLED=false
GITHUB_PERSONAL_ACCESS_TOKEN=

SERP_ENABLED=false
SERPAPI_API_KEY=

